# ── ActBoard Server ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Port the server listens on (default: 3141)
PORT=3141

# Bind address (default: 0.0.0.0 — accessible on all interfaces)
HOST=0.0.0.0

# Directory where the SQLite database file is stored
# Default: ./data/actboard.db relative to the server directory
DATA_DIR=./data

# CORS allowed origin (default: * — allow all)
# Set this to your frontend URL in production, e.g.:
# CORS_ORIGIN=https://actboard.yourcompany.com
CORS_ORIGIN=*

# ── Playwright Reporter (set in your CI environment) ─────────────────────────
# Copy this key from the ActBoard dashboard → Settings → API Keys

ACTBOARD_SERVER_URL=http://localhost:3141
ACTBOARD_API_KEY=act_yourproject_your_key_here
ACTBOARD_PROJECT=your-project-slug
