{
  "name": "@actboard/playwright-reporter",
  "version": "1.0.5",
  "description": "Playwright reporter for full test history, pass-rate trends, and flaky test detection — powered by ActBoard",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "playwright",
    "playwright-reporter",
    "playwright-plugin",
    "playwright-analytics",
    "playwright-history",
    "playwright-dashboard",
    "playwright-results",
    "playwright-ci",
    "test-history",
    "test-analytics",
    "test-dashboard",
    "test-reporting",
    "test-trends",
    "test-monitoring",
    "test-observability",
    "test-metrics",
    "test-results",
    "flaky-tests",
    "flaky-test-detection",
    "flakey-tests",
    "pass-rate",
    "ci-analytics",
    "ci-monitoring",
    "e2e",
    "e2e-testing",
    "e2e-reporter",
    "testing",
    "dashboard",
    "self-hosted",
    "self-hostable",
    "github-actions",
    "actboard",
    "regression-tracking",
    "test-suite-history",
    "qa-dashboard",
    "continuous-testing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/actboard/actboard.git",
    "directory": "reporter"
  },
  "homepage": "https://actboard.io",
  "bugs": {
    "url": "https://github.com/actboard/actboard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "socket": {
    "networkAccess": true
  },
  "peerDependencies": {
    "@playwright/test": ">=1.38.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.5"
  }
}
